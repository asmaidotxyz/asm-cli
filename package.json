{
  "name": "aiasm",
  "version": "0.1.5",
  "module": "index.ts",
  "author": "Duc Huy <imduchuyyy@gmail.com>",
  "description": "The CLI for agent to manage their skills.",
  "homepage": "https://aiasm.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/instructionai/aiasm.git"
  },
  "license": "MIT",
  "type": "module",
  "private": false,
  "keywords": [
    "agent-skills-manager",
    "ai",
    "agent",
    "skills",
    "cli"
  ],
  "scripts": {
    "build": "rm -rf build && bun build ./index.ts --compile --outfile build/asm && cp package.json build/",
    "prepare": "bun run build",
    "dev": "bun run build --watch"
  },
  "bin": {
    "asm": "./asm"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "axios": "^1.16.1",
    "commander": "^14.0.3"
  }
}
